{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "devCommand": "cd frontend && npm run dev",
  "installCommand": "cd frontend && npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://156.67.30.58:3001/api/:path*"
    },
    {
      "source": "/health",
      "destination": "http://156.67.30.58:3001/health"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://156.67.30.58:3001/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
